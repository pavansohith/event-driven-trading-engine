REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:password@localhost:5432/trading

# Binance Spot Testnet REST endpoint (BINANCE_TESTNET_URL is preferred; BINANCE_BASE_URL is fallback)
BINANCE_TESTNET_URL=https://testnet.binance.vision
BINANCE_BASE_URL=https://testnet.binance.vision

# Must match ENCRYPTION_SECRET in apps/api — used to decrypt per-user Binance keys from PostgreSQL
ENCRYPTION_SECRET=change_me_encryption_secret

# Binance Testnet API credentials (per user, not service-level env vars)
# This service executes orders using keys stored in the database at signup (apps/api encrypts them).
# Create keys at https://testnet.binance.vision/ and register via the web app or POST /auth/register.
# Example values (do not commit real keys):
# BINANCE_API_KEY=your_testnet_api_key
# BINANCE_SECRET_KEY=your_testnet_secret_key
